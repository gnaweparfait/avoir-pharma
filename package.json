{
  "name": "avoirpharma",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node scripts/prisma-generate-safe.mjs",
    "db:generate": "node scripts/prisma-generate-safe.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate:force": "cmd /c \"taskkill /F /IM node.exe >nul 2>&1 & node scripts/prisma-generate-safe.mjs\"",
    "db:seed": "prisma db seed",
    "db:setup": "prisma migrate deploy && npm run db:generate && prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@zxing/browser": "^0.1.5",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.10",
    "jspdf": "^4.2.1",
    "next": "16.2.1",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
