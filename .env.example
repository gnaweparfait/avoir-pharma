# Copier ce fichier vers .env a la racine du projet, puis remplir les valeurs.
# Commande : copy .env.example .env   (Windows)   ou   cp .env.example .env

# PostgreSQL
DATABASE_URL="postgresql://USER:MOT_DE_PASSE@localhost:5432/avoirpharma?schema=public"

# Obligatoire pour la connexion web : au moins 32 caracteres aleatoires
AUTH_SECRET=

# Compte administrateur (utilise par : npm run db:seed)
ADMIN_EMAIL=admin@pharmacie.local
ADMIN_PASSWORD=
